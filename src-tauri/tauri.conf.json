{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slicky",
  "version": "0.1.0",
  "identifier": "app.slicky.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Slicky",
        "width": 300,
        "height": 360,
        "minWidth": 260,
        "minHeight": 160,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": false,
        "shadow": false,
        "fullscreen": false,
        "focus": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.openai.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Instant AI explanations from screenshots",
    "longDescription": "Press a hotkey, snip a region of your screen, and Slicky explains the concept instantly using AI.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
